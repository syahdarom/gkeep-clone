{
  "name": "gkeep-clone",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:root": "eslint .",
    "format:c": "prettier -c .",
    "format:w": "prettier -w .",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@eslint/json": "^0.12.0",
    "eslint": "^9.30.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "globals": "^16.2.0",
    "prettier": "^3.6.0",
    "prettier-plugin-organize-imports": "^4.1.0",
    "turbo": "^2.5.4",
    "typescript": "5.8.2",
    "typescript-eslint": "^8.35.0"
  }
}
